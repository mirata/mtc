}

ACTOR TracerBullet : FastProjectile
{
	Radius 1
	Height 1
	Speed 250
	//Damage (random (10, 10))
	+MISSILE
	+BLOODSPLATTER
	-ACTIVATEIMPACT
	-ACTIVATEPCROSS
  +NOTRIGGER
	Renderstyle Add
	Scale 0.2
	
	States
	{
	Spawn:
		TRAC A 1
		TRAC A -1
		Loop
	Death:
		TNT1 A 0
		//TNT1 A 0 A_SpawnItem("TracerPuff")
		Stop

	XDeath:
		TNT1 A 0
		Stop
	}
}

